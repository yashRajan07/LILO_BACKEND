# ── LILO Voice Assistant — Environment Variables ──────────────────
# Copy this file to .env and fill in your API keys.

# OpenAI (LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Sarvam AI (TTS)
SARVAM_API_KEY=your_sarvam_api_key_here

# Server (Local development or Container run settings)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=False # Set to True for local development hot-reloading



